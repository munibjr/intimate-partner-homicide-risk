{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 04: Model Explainability with SHAP\n",
    "\n",
    "Understanding what factors drive risk predictions using SHAP (SHapley Additive exPlanations)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import shap\n",
    "from sklearn.model_selection import train_test_split\n",
    "from src.data.case_generator import CaseGenerator\n",
    "from src.data.feature_extractor import FeatureExtractor\n",
    "from src.models.ensemble import RiskEnsemble\n",
    "from src.explainability.shap_explainer import RiskExplainer"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Train Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Prepare data\n",
    "gen = CaseGenerator(seed=42)\n",
    "cases = gen.generate_dataset(n_cases=500)\n",
    "extractor = FeatureExtractor()\n",
    "features_list = [extractor.extract_features(c) for c in cases]\n",
    "\n",
    "feature_names = [\n",
    "    'violence_incidents', 'max_violence_severity', 'violence_escalation_rate',\n",
    "    'threat_frequency', 'weapon_mention', 'threat_severity_max',\n",
    "    'isolation_indicators', 'restraining_order_breaches', 'police_contact_frequency',\n",
    "    'child_welfare_contact', 'days_since_last_incident', 'trend_worsening',\n",
    "    'velocity_of_escalation', 'multiple_agencies_involved', 'breach_of_protection'\n",
    "]\n",
    "\n",
    "X = np.array([[f[feat] for feat in feature_names] for f in features_list])\n",
    "y = np.array([f['risk_label'] for f in features_list])\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)\n",
    "\n",
    "# Train\n",
    "model = RiskEnsemble(random_state=42)\n",
    "model.fit(X_train, y_train)\n",
    "\n",
    "print(\"Model trained successfully\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SHAP Feature Importance"
   ]
  },
  {
   "cell_type": {"text": "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create explainer\n",
    "explainer = RiskExplainer(model.model, X_train, feature_names)\n",
    "\n",
    "# Explain test set\n",
    "shap_values = explainer.explainer.shap_values(X_test)\n",
    "\n",
    "print(f\"SHAP values computed for {len(X_test)} test cases\")\n",
    "print(f\"Shape: {shap_values.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Global Feature Importance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Summary plot (mean absolute SHAP values)\n",
    "mean_abs_shap = np.abs(shap_values).mean(axis=0)\n",
    "feature_importance = pd.DataFrame({\n",
    "    'Feature': feature_names,\n",
    "    'Mean |SHAP|': mean_abs_shap\n",
    "}).sort_values('Mean |SHAP|', ascending=False)\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.barh(feature_importance['Feature'][::-1], feature_importance['Mean |SHAP|'][::-1])\n",
    "plt.xlabel('Mean |SHAP Value|')\n",
    "plt.title('Feature Importance (Mean Absolute SHAP Values)')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nTop 10 Most Important Features:\")\n",
    "print(feature_importance.head(10).to_string(index=False))"
   ]
  },
  {
   "cell_type": {"text": "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "## Individual Case Explanation\n",
    "\n",
    "Example of explaining a single high-risk prediction:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Find a high-risk case\n",
    "high_risk_indices = np.where((y_test == 1) & (model.predict_proba(X_test)[:, 1] > 0.7))[0]\n",
    "\n",
    "if len(high_risk_indices) > 0:\n",
    "    case_idx = high_risk_indices[0]\n",
    "    case_features = X_test[case_idx]\n",
    "    \n",
    "    explanation = explainer.explain_case(case_features)\n",
    "    \n",
    "    print(f\"Risk Score: {explanation['risk_score']:.1f}/100\")\n",
    "    print(f\"\\nTop Risk-Increasing Factors:\")\n",
    "    for i, factor in enumerate(explanation['top_increasing_factors'][:5], 1):\n",
    "        print(f\"  {i}. {factor['feature']}: +{factor['contribution']:.3f}\")\n",
    "    \n",
    "    print(f\"\\nTop Risk-Decreasing Factors:\")\n",
    "    for i, factor in enumerate(explanation['top_decreasing_factors'][:5], 1):\n",
    "        print(f\"  {i}. {factor['feature']}: {factor['contribution']:.3f}\")\n",
    "    \n",
    "    print(f\"\\nRecommended Actions:\")\n",
    "    for action in explanation['recommended_actions']:\n",
    "        print(f\"  - {action}\")\n",
    "else:\n",
    "    print(\"No high-risk cases with >0.7 probability found in test set\")"
   ]
  }
 ],
