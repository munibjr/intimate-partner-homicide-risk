 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 05: Fairness Auditing\n",
    "\n",
    "Detecting and mitigating bias across demographic groups."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.model_selection import train_test_split\n",
    "import seaborn as sns\n",
    "from src.data.case_generator import CaseGenerator\n",
    "from src.data.feature_extractor import FeatureExtractor\n",
    "from src.models.ensemble import RiskEnsemble\n",
    "from src.evaluation.fairness_audit import FairnessAudit\n",
    "\n",
    "sns.set_style('whitegrid')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Setup and Training"
   ]
  },
  {
   "cell_type": {"text": "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate data with demographics\n",
    "gen = CaseGenerator(seed=42)\n",
    "cases = gen.generate_dataset(n_cases=500)\n",
    "\n",
    "# Add synthetic demographics\n",
    "for i, case in enumerate(cases):\n",
    "    case['age_group'] = np.random.choice(['young', 'middle', 'older'])\n",
    "    case['income_level'] = np.random.choice(['low', 'medium', 'high'])\n",
    "    case['nationality'] = np.random.choice(['norwegian', 'immigrant'])\n",
    "\n",
    "# Extract features\n",
    "extractor = FeatureExtractor()\n",
    "features_list = [extractor.extract_features(c) for c in cases]\n",
    "\n",
    "feature_names = [\n",
    "    'violence_incidents', 'max_violence_severity', 'violence_escalation_rate',\n",
    "    'threat_frequency', 'weapon_mention', 'threat_severity_max',\n",
    "    'isolation_indicators', 'restraining_order_breaches', 'police_contact_frequency',\n",
    "    'child_welfare_contact', 'days_since_last_incident', 'trend_worsening',\n",
    "    'velocity_of_escalation', 'multiple_agencies_involved', 'breach_of_protection'\n",
    "]\n",
    "\n",
    "X = np.array([[f[feat] for feat in feature_names] for f in features_list])\n",
    "y = np.array([f['risk_label'] for f in features_list])\n",
    "\n",
    "# Split\n",
    "X_train, X_test, y_train, y_test, cases_train, cases_test = train_test_split(\n",
    "    X, y, cases, test_size=0.3, random_state=42\n",
    ")\n",
    "\n",
    "# Train\n",
    "model = RiskEnsemble(random_state=42)\n",
    "model.fit(X_train, y_train)\n",
    "\n",
    "# Get predictions on test set\n",
    "predictions = (model.predict_proba(X_test)[:, 1] > 0.5).astype(int)\n",
    "\n",
    "print(\"Model trained with demographics\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Demographic Parity Analysis"
   ]
  },
  {
   "cell_type": {"text": "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Audit by nationality\n",
    "audit = FairnessAudit()\n",
    "\n",
    "nationalities = np.array([c.get('nationality') for c in cases_test])\n",
    "parity_results = audit.audit_demographic_parity(predictions, nationalities, 'nationality')\n",
    "\n",
    "print(\"Demographic Parity (by Nationality):\")\n",
    "print(parity_results)"
   ]
  },
  {
   "cell_type": {"text": "execution_count": null,\n",
    "metadata": {},\n",
    "outputs": [],\n",
    "source": ["# Visualize positive prediction rates\n", "nationalities_unique = np.unique(nationalities)\n", "positive_rates = []\n", "\n", "for nat in nationalities_unique:\n", "    mask = nationalities == nat\n", "    rate = (predictions[mask] == 1).sum() / mask.sum()\n", "    positive_rates.append(rate)\n", "\n", "plt.figure(figsize=(8, 5))\n", "plt.bar(nationalities_unique, positive_rates, color=['steelblue', 'coral'])\n", "plt.ylabel('Positive Prediction Rate')\n", "plt.xlabel('Nationality')\n", "plt.title('Demographic Parity: Prediction Rate by Nationality')\n", "plt.ylim([0, 1])\n", "for i, v in enumerate(positive_rates):\n", "    plt.text(i, v + 0.02, f'{v:.2%}', ha='center', fontweight='bold')\n", "plt.show()"]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Equalized Odds Analysis"
   ]
  },
  {
   "cell_type": {"text": "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Audit equalized odds\n",
    "age_groups = np.array([c.get('age_group') for c in cases_test])\n",
    "odds_results = audit.audit_equalized_odds(predictions, age_groups, y_test, 'age_group')\n",
    "\n",
    "print(\"\\nEqualized Odds (by Age Group):\")\n",
    "print(odds_results)"
   ]
  },
  {
   "cell_type": {"text": "execution_count": null,\n",
    "metadata": {},\n",
    "outputs": [],\n",
    "source": ["# Visualize TPR and FPR by age group\n", "age_unique = np.unique(age_groups)\n", "tprs = []\n", "fprs = []\n", "\n", "for age in age_unique:\n", "    mask = age_groups == age\n", "    group_y = y_test[mask]\n", "    group_pred = predictions[mask]\n", "    \n", "    if len(np.unique(group_y)) > 1 and len(group_y) > 0:\n", "        from sklearn.metrics import confusion_matrix\n", "        tn, fp, fn, tp = confusion_matrix(group_y, group_pred).ravel()\n", "        tpr = tp / (tp + fn) if (tp + fn) > 0 else 0\n", "        fpr = fp / (fp + tn) if (fp + tn) > 0 else 0\n", "        tprs.append(tpr)\n", "        fprs.append(fpr)\n", "\n", "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 5))\n", "ax1.bar(age_unique[:len(tprs)], tprs, color='steelblue')\n", "ax1.set_ylabel('True Positive Rate')\n", "ax1.set_title('TPR by Age Group')\n", "ax1.set_ylim([0, 1])\n", "\n", "ax2.bar(age_unique[:len(fprs)], fprs, color='coral')\n", "ax2.set_ylabel('False Positive Rate')\n", "ax2.set_title('FPR by Age Group')\n", "ax2.set_ylim([0, 1])\n", "\n", "plt.tight_layout()\n", "plt.show()"]
  },
  {
   "cell_type": {"text": "execution_count": null,\n",
    "metadata": {},\n",
    "outputs": [],\n",
    "source": ["## Conclusion\n", "\n", "audit.print_audit_summary()"]
  }
 ],
