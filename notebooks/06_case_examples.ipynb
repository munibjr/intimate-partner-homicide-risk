   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 06: Case Examples & Risk Walkthroughs\n",
    "\n",
    "Detailed explanations of high-risk and low-risk cases with model predictions and recommendations."
   ]
  },
  {
   "cell_type": {"text": "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "from sklearn.model_selection import train_test_split\n",
    "from src.data.case_generator import CaseGenerator\n",
    "from src.data.feature_extractor import FeatureExtractor\n",
    "from src.models.ensemble import RiskEnsemble\n",
    "from src.explainability.shap_explainer import RiskExplainer"]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Prepare data and train model\n",
    "gen = CaseGenerator(seed=42)\n",
    "cases = gen.generate_dataset(n_cases=500)\n",
    "\n",
    "extractor = FeatureExtractor()\n",
    "features_list = [extractor.extract_features(c) for c in cases]\n",
    "\n",
    "feature_names = [\n",
    "    'violence_incidents', 'max_violence_severity', 'violence_escalation_rate',\n",
    "    'threat_frequency', 'weapon_mention', 'threat_severity_max',\n",
    "    'isolation_indicators', 'restraining_order_breaches', 'police_contact_frequency',\n",
    "    'child_welfare_contact', 'days_since_last_incident', 'trend_worsening',\n",
    "    'velocity_of_escalation', 'multiple_agencies_involved', 'breach_of_protection'\n",
    "]\n",
    "\n",
    "X = np.array([[f[feat] for feat in feature_names] for f in features_list])\n",
    "y = np.array([f['risk_label'] for f in features_list])\n",
    "\n",
    "X_train, X_test, y_train, y_test, cases_train, cases_test = train_test_split(\n",
    "    X, y, cases, test_size=0.3, random_state=42\n",
    ")\n",
    "\n",
    "model = RiskEnsemble(random_state=42)\n",
    "model.fit(X_train, y_train)\n",
    "\n",
    "explainer = RiskExplainer(model.model, X_train, feature_names)\n",
    "\n",
    "print(f\"Model ready for {len(X_test)} test cases\")"
   ]
  },
  {
   "cell_type": {"text": "execution_count": null,\n",
    "metadata": {},\n",
    "outputs": [],\n",
    "source": ["## HIGH-RISK CASE EXAMPLE\n", "\n", "A case showing classic escalation pattern:"]
  },
  {
   "cell_type": {"text": "execution_count": null,\n",
    "metadata": {},\n",
    "outputs": [],\n",
    "source": ["# Find a true positive (actually high-risk, correctly predicted)\n", "y_pred_proba = model.predict_proba(X_test)[:, 1]\n", "true_positives = np.where((y_test == 1) & (y_pred_proba > 0.7))[0]\n", "\n", "if len(true_positives) > 0:\n", "    idx = true_positives[0]\n", "    case = cases_test[idx]\n", "    features = X_test[idx]\n", "    risk_score = model.get_risk_scores(X_test[idx:idx+1])[0]\n", "    \n", "    print(f\"CASE ID: {idx}\")\n", "    print(f\"\\nRISK ASSESSMENT: {risk_score:.0f}/100\")\n", "    print(f\"RISK CATEGORY: \", end=\"\")\n", "    if risk_score >= 70:\n", "        print(\"HIGH RISK\")\n", "    elif risk_score >= 40:\n", "        print(\"MEDIUM RISK\")\n", "    else:\n", "        print(\"LOW RISK\")\n", "    \n", "    print(f\"\\nCASE TIMELINE:\")\n", "    print(f\"Start Date: {case['start_date']}\")\n", "    print(f\"\\nKey Indicators:\")\n", "    print(f\"  - Violence Incidents: {case['violence_incidents']}\")\n", "    print(f\"  - Threats: {case['threat_frequency']}\")\n", "    print(f\"  - Weapons Mentioned: {'Yes' if case['weapon_mention'] else 'No'}\")\n", "    print(f\"  - Restraining Order Breaches: {case['restraining_order_breaches']}\")\n", "    print(f\"  - Police Contact Frequency: {case['police_contact_frequency']:.2f}\")\n", "    print(f\"  - Agency Involvement: {case['multiple_agencies_involved']} agencies\")\n", "    \n", "    print(f\"\\nEvent Timeline (most recent):\")\n", "    for event in case['events'][-5:]:\n", "        print(f\"  {event['date']}: {event['event_type']}\")\n", "    \n", "    # SHAP explanation\n", "    explanation = explainer.explain_case(features)\n", "    print(f\"\\nTop Risk Factors:\")\n", "    for i, factor in enumerate(explanation['top_increasing_factors'][:5], 1):\n", "        print(f\"  {i}. {factor['feature']}: +{factor['contribution']:.3f}\")\n", "    \n", "    print(f\"\\nRecommended Actions:\")\n", "    for action in explanation['recommended_actions']:\n", "        print(f\"  ✓ {action}\")"
   ]
  },
  {
   "cell_type": {"text": "execution_count": null,\n",
    "metadata": {},\n",
    "outputs": [],\n",
    "source": ["## LOW-RISK CASE EXAMPLE\n", "\n", "A case showing isolated incident, properly resolved:"]
  },
  {
   "cell_type": {"text": "execution_count": null,\n",
    "metadata": {},\n",
    "outputs": [],\n",
    "source": ["# Find a true negative (actually low-risk, correctly predicted)\n", "true_negatives = np.where((y_test == 0) & (y_pred_proba < 0.3))[0]\n", "\n", "if len(true_negatives) > 0:\n", "    idx = true_negatives[0]\n", "    case = cases_test[idx]\n", "    features = X_test[idx]\n", "    risk_score = model.get_risk_scores(X_test[idx:idx+1])[0]\n", "    \n", "    print(f\"CASE ID: {idx}\")\n", "    print(f\"\\nRISK ASSESSMENT: {risk_score:.0f}/100\")\n", "    print(f\"RISK CATEGORY: \", end=\"\")\n", "    if risk_score >= 70:\n", "        print(\"HIGH RISK\")\n", "    elif risk_score >= 40:\n", "        print(\"MEDIUM RISK\")\n", "    else:\n", "        print(\"LOW RISK\")\n", "    \n", "    print(f\"\\nCASE TIMELINE:\")\n", "    print(f\"Start Date: {case['start_date']}\")\n", "    print(f\"\\nKey Indicators:\")\n", "    print(f\"  - Violence Incidents: {case['violence_incidents']}\")\n", "    print(f\"  - Threats: {case['threat_frequency']}\")\n", "    print(f\"  - Weapons Mentioned: {'Yes' if case['weapon_mention'] else 'No'}\")\n", "    print(f\"  - Restraining Order Breaches: {case['restraining_order_breaches']}\")\n", "    print(f\"  - Police Contact Frequency: {case['police_contact_frequency']:.2f}\")\n", "    print(f\"  - Agency Involvement: {case['multiple_agencies_involved']} agencies\")\n", "    \n", "    print(f\"\\nEvent Timeline:\")\n", "    for event in case['events']:\n", "        print(f\"  {event['date']}: {event['event_type']}\")\n", "    \n", "    print(f\"\\nCase Status: RESOLVED - Single incident, no escalation pattern detected\")"
   ]
  },
  {
   "cell_type": {"text": "execution_count": null,\n",
    "metadata": {},\n",
    "outputs": [],\n",
    "source": ["## COMPARISON: Risk Distribution\n", "\n", "How the model distinguishes high-risk from low-risk:"]
  },
  {
   "cell_type": {"text": "execution_count": null,\n",
    "metadata": {},\n",
    "outputs": [],\n",
    "source": ["import matplotlib.pyplot as plt\n", "\n", "# Plot predicted probabilities\n", "plt.figure(figsize=(12, 6))\n", "\n", "# High-risk cases\n", "high_risk_probs = y_pred_proba[y_test == 1]\n", "plt.hist(high_risk_probs, bins=20, alpha=0.6, label='Actually High-Risk', color='red')\n", "\n", "# Low-risk cases\n", "low_risk_probs = y_pred_proba[y_test == 0]\n", "plt.hist(low_risk_probs, bins=20, alpha=0.6, label='Actually Low-Risk', color='green')\n", "\n", "plt.axvline(0.5, color='black', linestyle='--', linewidth=2, label='Decision Threshold')\n", "plt.xlabel('Predicted Risk Probability')\n", "plt.ylabel('Frequency')\n", "plt.title('Model Risk Probability Distribution')\n", "plt.legend()\n", "plt.grid(alpha=0.3)\n", "plt.show()\n", "\n", "# Statistics\n", "print(f\"High-Risk Cases:\")\n", "print(f\"  Mean predicted probability: {high_risk_probs.mean():.3f}\")\n", "print(f\"  Correctly identified (>0.5): {(high_risk_probs > 0.5).sum()} / {len(high_risk_probs)}\")\n", "\n", "print(f\"\\nLow-Risk Cases:\")\n", "print(f\"  Mean predicted probability: {low_risk_probs.mean():.3f}\")\n", "print(f\"  Correctly identified (<0.5): {(low_risk_probs < 0.5).sum()} / {len(low_risk_probs)}\")"
   ]
  }
 ],
